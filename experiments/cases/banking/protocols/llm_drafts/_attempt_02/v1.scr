module v1;

data <java> "java.lang.Double" from "rt.jar" as Double;
data <java> "java.lang.String" from "rt.jar" as String;
data <java> "java.lang.Boolean" from "rt.jar" as Bool;

global protocol BankingTransfer(role Initiator, role SourceBank, role DestBank, role Approver, role AuditLog) {
    TransferRequest(Double) from Initiator to SourceBank;

    choice at SourceBank {
        HighAmountApprovalRequired() from SourceBank to Approver; // Notify Approver
        HighAmountApprovalRequired() from SourceBank to DestBank; // Notify DestBank
        HighAmountApprovalRequired() from SourceBank to AuditLog; // Notify AuditLog
        Approval(Bool) from Approver to SourceBank;
        choice at Approver {
            Approved() from Approver to SourceBank;
            Approved() from Approver to DestBank;
            Approved() from Approver to AuditLog;
        } or {
            Rejected() from Approver to SourceBank;
            Rejected() from Approver to AuditLog;
        }
    } or {
        StandardAmountProceed() from SourceBank to DestBank; // Notify DestBank
        StandardAmountProceed() from SourceBank to AuditLog; // Notify AuditLog
    }

    choice at SourceBank {
        SuccessDebit(Double) from SourceBank to DestBank; // Source debits; notify DestBank
        SuccessDebit(Double) from SourceBank to AuditLog; // Notify AuditLog
    } or {
        FailureDebit(String) from SourceBank to AuditLog; // Debit fails; notify AuditLog
    }

    FinalOutcome(String) from AuditLog to Initiator;
    Settled() from AuditLog to Initiator;
}