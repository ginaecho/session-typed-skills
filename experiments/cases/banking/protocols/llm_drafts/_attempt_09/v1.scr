module v1;

data <java> "java.lang.Double" from "rt.jar" as Double;
data <java> "java.lang.String" from "rt.jar" as String;
data <java> "java.lang.Boolean" from "rt.jar" as Bool;

global protocol BankingTransfer(role Initiator, role SourceBank, role DestBank, role Approver, role AuditLog) {
    TransferRequest(Double) from Initiator to SourceBank;

    choice at SourceBank {
        RequiresApproval() from SourceBank to Approver;
        ApprovalGranted(Bool) from Approver to SourceBank;

        choice at Approver {
            Authorized() from Approver to SourceBank;
            AuthorizationRejected(String) from Approver to Initiator;
        } or {
            FundsAvailable() from SourceBank to DestBank;
            DebitConfirmation(Bool) from DestBank to Initiator;
	       BalanceAcknowledgement)}