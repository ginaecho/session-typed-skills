module v1;

data <java> "java.lang.Double" from "rt.jar" as Double;
data <java> "java.lang.String" from "rt.jar" as String;
data <java> "java.lang.Boolean" from "rt.jar" as Bool;

global protocol BankingTransfer(role Initiator, role SourceBank, role DestBank, role Approver, role AuditLog) {
    TransferRequest(Double) from Initiator to SourceBank;

    choice at SourceBank {
        HighAmountApprovalRequired() from SourceBank to Approver;
        NotifyHighAmountApprovalRequired() from SourceBank to DestBank;
        NotifyHighAmountApprovalRequired() from SourceBank to AuditLog;

        Approval(Bool) from Approver to SourceBank;

        choice at SourceBank {
            Approved() from SourceBank to DestBank;
            NotifyApproval() from SourceBank to AuditLog;
            NotifyApproval() from SourceBank to Approver;

            ApprovedDebit(Double) from SourceBank to DestBank;
            NotifyDebitSuccess(Double) from SourceBank to AuditLog;
        } or {
            Rejected() from SourceBank to DestBank;
            NotifyRejection() from SourceBank to AuditLog;
            NotifyRejection() from SourceBank to Approver;

            FailureDebit(String) from SourceBank to DestBank;
            NotifyDebitFailure(String) from SourceBank to AuditLog;
        }
    } or {
        StandardAmountProceed() from SourceBank to DestBank;
        NotifyStandardAmountProceed() from SourceBank to AuditLog;
        NotifyStandardAmountProceed() from SourceBank to Approver;

        SuccessDebit(Double) from SourceBank to DestBank;
        NotifyDebitSuccess(Double) from SourceBank to AuditLog;
    }

    FinalOutcome(String) from AuditLog to Initiator;
    Settled() from AuditLog to Initiator;
}