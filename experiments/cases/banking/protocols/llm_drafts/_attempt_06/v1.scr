module v1;

data <java> "java.lang.Double" from "rt.jar" as Double;
data <java> "java.lang.String" from "rt.jar" as String;
data <java> "java.lang.Boolean" from "rt.jar" as Bool;

global protocol BankingTransfer(role Initiator, role SourceBank, role DestBank, role Approver, role AuditLog) {
    TransferRequest(Double) from Initiator to SourceBank;

    choice at SourceBank {
        AboveThreshold(Double) from SourceBank to Approver;
        choice at Approver {
            AuthorizationGranted() from Approver to SourceBank;
            DebitSucceeded(Double) from SourceBank to DestBank;
            CreditSucceeded(Double) from DestBank to AuditLog;
            SuccessLogged(String) from AuditLog to Initiator;
            Settled(String) from AuditLog to Initiator;
        } or {
            AuthorizationDenied(String) from Approver to Initiator;
            RejectionLogged(String) from SourceBank to AuditLog;
            Settled(String) from AuditLog to Initiator;
        }
    } or {
        BelowThreshold(Double) from SourceBank to DestBank;
        DebitSucceeded(Double) from SourceBank to DestBank;
        CreditSucceeded(Double) from DestBank to AuditLog;
        SuccessLogged(String) from AuditLog to Initiator;
        Settled(String) from AuditLog to Initiator;
    }
}