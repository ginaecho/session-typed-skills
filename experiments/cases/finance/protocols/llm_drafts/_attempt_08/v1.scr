module v1;

data <java> "java.lang.Double" from "rt.jar" as Double;
data <java> "java.lang.Boolean" from "rt.jar" as Bool;
data <java> "java.lang.String" from "rt.jar" as String;

global protocol QuarterlyFinanceReport(role Fetcher, role RevenueAnalyst, role ExpenseAnalyst, role Writer, role TaxVerifier, role TaxSpecialist) {
    FetchRevenueData() from Fetcher to RevenueAnalyst;
    FetchExpenseData() from Fetcher to ExpenseAnalyst;

    AnalyzeExpenses() from ExpenseAnalyst to Writer;

    choice at RevenueAnalyst {
        HighRevenue(Double) from RevenueAnalyst to TaxSpecialist;
        HighAuditNotification(String) from RevenueAnalyst to TaxVerifier;
        HighBranchNotification(String) from RevenueAnalyst to ExpenseAnalyst;
        HighRevenueNotification(String) from RevenueAnalyst to Writer;

        AuditRequest(String) from RevenueAnalyst to TaxSpecialist;
        AuditApproval(Bool) from TaxSpecialist to TaxVerifier;

        HighBranchAck(String) from TaxVerifier to ExpenseAnalyst;
        HighRevenueAck(String) from TaxVerifier to Writer;
    } or {
        StandardRevenue(Double) from RevenueAnalyst to TaxVerifier;
        StandardBranchNotification(String) from RevenueAnalyst to ExpenseAnalyst;
        StandardRevenueNotification(String) from RevenueAnalyst to Writer;

        StandardBranchAck(String) from TaxVerifier to ExpenseAnalyst;
        StandardRevenueAck(String) from TaxVerifier to Writer;
    }

    VerifyApproval(Bool) from TaxVerifier to Writer;
    GenerateReport() from Writer to Fetcher;
}