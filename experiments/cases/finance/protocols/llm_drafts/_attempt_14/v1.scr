module v1;

data <java> "java.lang.Double" from "rt.jar" as Double;
data <java> "java.lang.String" from "rt.jar" as String;

global protocol QuarterlyFinanceReport(role Fetcher, role RevenueAnalyst, role ExpenseAnalyst, role Writer, role TaxVerifier, role TaxSpecialist) {
    FetchRawData() from Fetcher to RevenueAnalyst;
    AnalyzeRevenue() from RevenueAnalyst to ExpenseAnalyst;
    AnalyzeExpenses() from ExpenseAnalyst to RevenueAnalyst;

    choice at RevenueAnalyst {
        HighRevenue(Double) from RevenueAnalyst to TaxSpecialist;
        AuditComplete() from TaxSpecialist to RevenueAnalyst;
    } or {
        StandardRevenue() from RevenueAnalyst to TaxVerifier;
    }

    Approval() from TaxVerifier to RevenueAnalyst;
    FinalizeAnalysis(String) from RevenueAnalyst to Writer;
    GenerateReport() from Writer to Fetcher;
}