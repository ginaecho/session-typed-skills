module v1;

data <java> "java.lang.Double" from "rt.jar" as Double;
data <java> "java.lang.String" from "rt.jar" as String;

global protocol QuarterlyFinanceReport(role Fetcher, role RevenueAnalyst, role ExpenseAnalyst, role TaxVerifier, role TaxSpecialist, role Writer) {
    FetchRevenueData() from Fetcher to RevenueAnalyst;
    FetchExpenseData() from Fetcher to ExpenseAnalyst;

    AnalyzeRevenue() from RevenueAnalyst to TaxVerifier;
    AnalyzeExpenses() from ExpenseAnalyst to TaxVerifier;

    choice at TaxVerifier {
        HighRevenueAudit() from TaxVerifier to TaxSpecialist;
        AuditComplete() from TaxSpecialist to TaxVerifier;
    } or {
        StandardApproval() from TaxVerifier to Writer;
    }

    FinalizeReport(String) from TaxVerifier to Writer;
    GenerateReport() from Writer to Fetcher;
}