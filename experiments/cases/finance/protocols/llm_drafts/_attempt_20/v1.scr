module v1;

data <java> "java.lang.Double" from "rt.jar" as Revenue;
data <java> "java.lang.String" from "rt.jar" as Report;

global protocol QuarterlyFinanceReport(role Fetcher, role RevenueAnalyst, role ExpenseAnalyst, role Writer, role TaxVerifier, role TaxSpecialist) {
    FetchRevenueData() from Fetcher to RevenueAnalyst;
    AnalyzeExpenses() from ExpenseAnalyst to RevenueAnalyst;
    choice at RevenueAnalyst {
        HighRevenue(Revenue) from RevenueAnalyst to TaxSpecialist;
        HighRevenueApproval() from TaxSpecialist to TaxVerifier;
    } or {
        StandardRevenue(Revenue) from RevenueAnalyst to TaxVerifier;
    }
    ApprovedRevenue() from TaxVerifier to Writer;
    GenerateReport(Report) from Writer to Fetcher;
}