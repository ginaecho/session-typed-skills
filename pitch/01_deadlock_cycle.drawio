        <mxCell id="orch" value="Orchestrator&#10;“ship the fix” job" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#3B82F6;gradientColor=#1D4ED8;strokeColor=#1D4ED8;fontColor=#FFFFFF;fontSize=12;shadow=1;" vertex="1" parent="1"><mxGeometry x="360" y="70" width="220" height="58" as="geometry"/></mxCell>
        <mxCell id="coder" value="Coder&#10;won’t push the patch&#10;until the Reviewer signs off" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FFFFFF;gradientColor=#F5F8FD;strokeColor=#2563EB;fontColor=#13315C;fontSize=12;shadow=1;" vertex="1" parent="1"><mxGeometry x="80" y="250" width="210" height="92" as="geometry"/></mxCell>
